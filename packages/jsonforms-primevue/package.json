{
  "name": "@uncharted.software/jsonforms-primevue",
  "version": "1.2.0",
  "description": "Vue 3 renderer set for JSON Forms (jsonforms.io) using PrimeVue 4",
  "type": "module",
  "main": "dist/jsonforms-primevue.cjs",
  "module": "dist/jsonforms-primevue.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/jsonforms-primevue.es.js",
      "require": "./dist/jsonforms-primevue.cjs"
    },
    "./style.css": "./dist/jsonforms-primevue.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "homepage": "https://uncharted-flatware.github.io/jsonforms-primevue-monorepo/",
  "bugs": {
    "url": "https://github.com/uncharted-flatware/jsonforms-primevue-monorepo/issues"
  },
  "keywords": [
    "jsonforms",
    "json-forms",
    "jsonforms.io",
    "primevue",
    "primevue4",
    "vue",
    "vue3",
    "vue-component",
    "json-schema",
    "jsonschema",
    "uischema",
    "ui-schema",
    "forms",
    "dynamic-forms",
    "form-renderer",
    "schema-driven"
  ],
  "author": "Derek Gray (Uncharted Software)",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uncharted-flatware/jsonforms-primevue-monorepo.git",
    "directory": "packages/jsonforms-primevue"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.5.0",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --ignore-path .prettierignore --write '**/*.{ts,tsx,vue,css,json,js,jsx}'",
    "format:ci": "prettier --ignore-path .prettierignore --check '**/*.{ts,tsx,vue,css,json,js,jsx}'",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:snapshots": "playwright test --update-snapshots",
    "ci": "yarn build && yarn lint && yarn lint:fix && yarn format && yarn format:ci && yarn test:unit:ci"
  },
  "peerDependencies": {
    "@jsonforms/core": "3.5.1",
    "@jsonforms/vue": "3.5.1",
    "primeflex": "^3.3.1",
    "primevue": "^4.4.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@jsonforms/core": "^3.5.1",
    "@jsonforms/vue": "^3.5.1",
    "@types/lodash": "^4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.5.1",
    "oxlint": "^0.16.12",
    "primeflex": "3.3.1",
    "primeicons": "7.0.0",
    "primevue": "4.4.1",
    "typescript": "^5.6.2",
    "vite": "^6.4.3",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.6"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "uuid": "^14.0.0"
  }
}
