{
  "name": "@unchartedsoftware/jsonforms-primevue",
  "version": "0.0.1",
  "description": "PrimeVue renderers for JSON-Forms",
  "type": "module",
  "main": "dist/jsonforms-primevue.umd.js",
  "module": "dist/jsonforms-primevue.es.js",
  "types": "dist/types/index.d.ts",
  "keywords": [
    "jsonforms",
    "vue",
    "primevue",
    "json-schema",
    "uischema",
    "forms",
    "library"
  ],
  "author": "Derek Gray",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.5.0",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --ignore-path .prettierignore --write '**/*.{ts,tsx,vue,css,json,js,jsx}'",
    "format:ci": "prettier --ignore-path .prettierignore --check '**/*.{ts,tsx,vue,css,json,js,jsx}'",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:snapshots": "playwright test --update-snapshots",
    "ci": "yarn build && yarn lint && yarn lint:fix && yarn format && yarn format:ci && yarn test:unit:ci"
  },
  "peerDependencies": {
    "@jsonforms/core": "3.5.1",
    "@jsonforms/vue": "3.5.1",
    "primeflex": "^3.3.1",
    "primevue": "^3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@jsonforms/core": "^3.5.1",
    "@jsonforms/vue": "^3.5.1",
    "@types/lodash": "^4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.5.5",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.5.1",
    "oxlint": "^0.16.12",
    "primeflex": "3.3.1",
    "primeicons": "7.0.0",
    "primevue": "3.53.0",
    "typescript": "^5.6.2",
    "vite": "^6.3.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.6"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "uuid": "^9.0.1"
  }
}
