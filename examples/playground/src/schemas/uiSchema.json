{
  "type": "VerticalLayout",
  "elements": [
    {
      "type": "Group",
      "label": "Basic Controls",
      "options": {
        "isToggleable": true,
        "isExpanded": false
      },
      "elements": [
        {
          "type": "Label",
          "text": "String Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/aString",
          "options": {
            "placeholder": "Enter a string value"
          }
        },
        {
          "type": "Label",
          "text": "Number Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/aNumber",
          "options": {
            "prefix": "$",
            "suffix": " USD"
          }
        },
        {
          "type": "Label",
          "text": "Integer Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/anInteger",
          "options": {
            "prefix": "#",
            "suffix": " items"
          }
        },
        {
          "type": "Label",
          "text": "Boolean Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/aBoolean"
        },
        {
          "type": "Label",
          "text": "Enum Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/anEnum"
        },
        {
          "type": "Label",
          "text": "Date-Time Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/aDateTime"
        },
        {
          "type": "Label",
          "text": "Duration Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/aDuration"
        }
      ]
    },
    {
      "type": "Group",
      "label": "UI Schema Rules (SHOW / HIDE / ENABLE / DISABLE)",
      "options": {
        "isToggleable": true,
        "isExpanded": true
      },
      "elements": [
        {
          "type": "Label",
          "text": "Toggle “Show advanced section” to exercise SHOW and HIDE on the fields below."
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/showAdvancedSection"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/advancedSectionNotes",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/testing/properties/rulesDemo/properties/showAdvancedSection",
              "schema": { "const": true }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/basicOnlyField",
          "rule": {
            "effect": "HIDE",
            "condition": {
              "scope": "#/properties/testing/properties/rulesDemo/properties/showAdvancedSection",
              "schema": { "const": true }
            }
          }
        },
        {
          "type": "Label",
          "text": "Toggle “Allow editing” and “Force locked mode” for DISABLE and ENABLE."
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/editingAllowed"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/editableField",
          "rule": {
            "effect": "DISABLE",
            "condition": {
              "scope": "#/properties/testing/properties/rulesDemo/properties/editingAllowed",
              "schema": { "const": false }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/forceLocked"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/lockedField",
          "rule": {
            "effect": "ENABLE",
            "condition": {
              "scope": "#/properties/testing/properties/rulesDemo/properties/forceLocked",
              "schema": { "const": false }
            }
          }
        },
        {
          "type": "Label",
          "text": "optionalCounter is omitted from Example Data so it starts undefined. JSON Schema often validates undefined as matching rules like minimum; failWhenUndefined forces the condition to fail when the scoped value is missing."
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/optionalCounter"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/detailWithoutFailWhenUndefined",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/testing/properties/rulesDemo/properties/optionalCounter",
              "schema": { "minimum": 1 }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/rulesDemo/properties/detailWithFailWhenUndefined",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/testing/properties/rulesDemo/properties/optionalCounter",
              "schema": { "minimum": 1 },
              "failWhenUndefined": true
            }
          }
        }
      ]
    },
    {
      "type": "Group",
      "label": "ControlWrapper Options Showcase",
      "options": {
        "isToggleable": true,
        "isExpanded": true
      },
      "elements": [
        {
          "type": "Label",
          "text": "Label Placement Options"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/defaultPlacement",
          "options": {
            "placeholder": "Default (left) label placement"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/topPlacement",
          "options": {
            "labelPlacement": "top",
            "placeholder": "Label appears above the field"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/rightPlacement",
          "options": {
            "labelPlacement": "right",
            "placeholder": "Label appears to the right"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/floatPlacement",
          "options": {
            "labelPlacement": "float",
            "placeholder": "Floating label inside field"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/hiddenLabel",
          "options": {
            "labelPlacement": "hide",
            "placeholder": "No label displayed"
          }
        },
        {
          "type": "Label",
          "text": "Description Display Options"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/tooltipDescription",
          "options": {
            "descriptionDisplay": "tooltip",
            "placeholder": "Hover over the info icon to see description"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/alwaysDescription",
          "options": {
            "descriptionDisplay": "always",
            "placeholder": "Description is always visible below"
          }
        },
        {
          "type": "Label",
          "text": "Field State Options"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/requiredField",
          "options": {
            "placeholder": "This field is required"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/visibleField",
          "options": {
            "placeholder": "This field is visible"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/focusedField",
          "options": {
            "focus": true,
            "placeholder": "This field receives focus when the form loads"
          }
        },
        {
          "type": "Label",
          "text": "Combined Options Examples"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/floatPlacement",
          "options": {
            "labelPlacement": "float",
            "descriptionDisplay": "always",
            "placeholder": "Float label with always-visible description"
          },
          "label": "Float + Always Description"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/topPlacement",
          "options": {
            "labelPlacement": "top",
            "descriptionDisplay": "tooltip",
            "placeholder": "Top label with tooltip description"
          },
          "label": "Top + Tooltip Description"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/controlWrapper/properties/rightPlacement",
          "options": {
            "labelPlacement": "right",
            "descriptionDisplay": "always",
            "placeholder": "Right label with always-visible description"
          },
          "label": "Right + Always Description"
        },
        {
          "type": "Group",
          "label": "Space-Between Layout Examples",
          "options": {
            "isToggleable": true,
            "isExpanded": true
          },
          "elements": [
            {
              "type": "Label",
              "text": "Space-Between Layout - Label and field fill width with space between"
            },
            {
              "type": "Control",
              "scope": "#/properties/testing/properties/controlWrapper/properties/spaceBetweenLeft",
              "options": {
                "labelPlacement": "left",
                "layout": "space-between",
                "placeholder": "Field on right side"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/testing/properties/controlWrapper/properties/spaceBetweenRight",
              "options": {
                "labelPlacement": "right",
                "layout": "space-between",
                "placeholder": "Field on left side"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/testing/properties/controlWrapper/properties/spaceBetweenShort",
              "options": {
                "labelPlacement": "left",
                "layout": "space-between",
                "placeholder": "Short label, full width"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/testing/properties/controlWrapper/properties/spaceBetweenLong",
              "options": {
                "labelPlacement": "left",
                "layout": "space-between",
                "placeholder": "Long label, still full width"
              }
            },
            {
              "type": "Control",
              "scope": "#/properties/testing/properties/controlWrapper/properties/spaceBetweenLong",
              "options": {
                "labelPlacement": "right",
                "layout": "space-between",
                "placeholder": "Field first, long label right"
              },
              "label": "Long Label on Right"
            }
          ]
        }
      ]
    },
    {
      "type": "Group",
      "label": "Complex Controls",
      "options": {
        "isToggleable": true,
        "isExpanded": false
      },
      "elements": [
        {
          "type": "Label",
          "text": "Array Control - Default Detail"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/tasks",
          "options": {
            "elementLabelProp": "name",
            "emptyMessage": "No tasks added yet",
            "showSortButtons": true,
            "detail": "DEFAULT"
          }
        },
        {
          "type": "Label",
          "text": "Array Control - Generated Detail"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/tasks",
          "options": {
            "elementLabelProp": "name",
            "emptyMessage": "No tasks added yet",
            "showSortButtons": true,
            "detail": "GENERATED"
          }
        },
        {
          "type": "Label",
          "text": "Array Control - Custom Layout"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/advancedTasks",
          "options": {
            "elementLabelProp": "name",
            "emptyMessage": "No advanced tasks added yet",
            "showSortButtons": true,
            "detail": {
              "type": "HorizontalLayout",
              "elements": [
                {
                  "type": "VerticalLayout",
                  "elements": [
                    {
                      "type": "Control",
                      "scope": "#/properties/name"
                    },
                    {
                      "type": "Control",
                      "scope": "#/properties/priority"
                    }
                  ]
                },
                {
                  "type": "VerticalLayout",
                  "elements": [
                    {
                      "type": "Control",
                      "scope": "#/properties/isCompleted"
                    },
                    {
                      "type": "Control",
                      "scope": "#/properties/dueDate"
                    }
                  ]
                }
              ]
            }
          }
        },
        {
          "type": "Label",
          "text": "Single Object Control"
        },
        {
          "type": "Control",
          "scope": "#/properties/testing/properties/anObject",
          "options": {
            "detail": {
              "type": "VerticalLayout",
              "elements": [
                {
                  "type": "Control",
                  "scope": "#/properties/name"
                },
                {
                  "type": "Control",
                  "scope": "#/properties/description"
                },
                {
                  "type": "Control",
                  "scope": "#/properties/tags"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "type": "Group",
      "label": "Layout Components",
      "options": {
        "isToggleable": true,
        "isExpanded": false
      },
      "elements": [
        {
          "type": "Label",
