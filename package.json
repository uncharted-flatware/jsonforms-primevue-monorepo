{
  "name": "@uncharted.software/jsonforms-primevue-monorepo",
  "version": "1.1.0",
  "description": "Monorepo for jsonforms-primevue package and example(s)",
  "author": "Derek Gray",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.7.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "yarn workspace @uncharted.software/jsonforms-primevue run build",
    "lint": "yarn workspaces foreach --all run lint",
    "test": "yarn workspaces foreach run test",
    "dev": "yarn workspace @uncharted.software/jsonforms-playground run dev"
  },
  "dependencies": {
    "@primevue/themes": "^4.4.1",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12"
  },
  "resolutions": {
    "@primeuix/styled": "0.7.4"
  }
}
